# ─────────────────────────────────────────────────────────────────────────────
# ASOS — Local Development with Mock Mode (no Meta/WhatsApp APIs needed)
# Copy to .env and fill in your real Claude API key.
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.local.example .env
#   docker compose --env-file .env up -d
#   docker compose exec api npx prisma migrate deploy
#   docker compose exec api node prisma/seed.js
#   docker compose exec api node prisma/seed-dsp.js
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── DATABASE ──────────────────────────────────────────────────────────────────
POSTGRES_DB=asos_db
POSTGRES_USER=asos_user
POSTGRES_PASSWORD=localdev_password
DATABASE_URL=postgresql://asos_user:localdev_password@postgres:5432/asos_db?schema=public

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (these are dev-only values, never use in production) ──────────────────
JWT_SECRET=dev_jwt_secret_change_this_to_64_chars_min_for_local_testing_only
JWT_REFRESH_SECRET=dev_refresh_secret_change_this_to_64_chars_min_for_local_dev

# ── CLAUDE (real key required — AI responses still fire in mock mode) ──────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6
CLOSER_MODEL=claude-sonnet-4-6
QUALIFIER_MODEL=claude-haiku-4-5-20251001

# ── WHATSAPP MOCK MODE ────────────────────────────────────────────────────────
# Setting this to true:
#   1. Skips all Meta API calls — no tokens needed
#   2. Mounts /api/v1/dev/inject-message endpoint for simulating inbound messages
#   3. Claude still processes all messages and writes replies to DB
WHATSAPP_MOCK=true
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_APP_SECRET=mock-secret-not-used
WHATSAPP_VERIFY_TOKEN=mock-verify-token-not-used

# ── REPLICATE (optional — for AI image generation in Content Studio) ───────────
# REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE

# ── APP ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
LOG_LEVEL=debug

# ── DSP-specific (optional legacy fields, defaults are fine) ──────────────────
DSP_DB_HOST=127.0.0.1
DSP_DB_PORT=3306
DSP_DB_NAME=dsp_crm
