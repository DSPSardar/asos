// This is your Prisma schema file
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  SUPERADMIN
  TENANT_ADMIN
  AGENT
}

enum LeadStage {
  NEW
  QUALIFYING
  DIAGNOSED
  PROPOSED
  CLOSED_WON
  CLOSED_LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum ConversationStatus {
  ACTIVE
  AI_HANDLING
  HUMAN_TAKEOVER
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  CONTACT
  AI
  AGENT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum ActivityType {
  NOTE
  STAGE_CHANGE
  AI_ACTION
  CALL
  EMAIL
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ─────────────────────────────────────────────
// TENANTS — Core multi-tenant entity
// ─────────────────────────────────────────────

model Tenant {
  id              String       @id @default(uuid())
  slug            String       @unique
  name            String
  plan            TenantPlan   @default(FREE)
  status          TenantStatus @default(TRIAL)

  // WhatsApp Cloud API credentials (encrypted at app layer)
  waPhoneId       String?      @map("wa_phone_id")
  waAccessToken   String?      @map("wa_access_token")
  waAppSecret     String?      @map("wa_app_secret")
  waVerifyToken   String?      @map("wa_verify_token")

  // Meta Ads / Conversions API
  metaPixelId       String?    @map("meta_pixel_id")
  metaAccessToken   String?    @map("meta_access_token")

  // Stripe billing
  stripeCustomerId  String?    @map("stripe_customer_id")

  // Settings (JSON blob for extensibility)
  settings        Json         @default("{}")

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  users           User[]
  contacts        Contact[]
  leads           Lead[]
  conversations   Conversation[]
  messages        Message[]
  campaigns       Campaign[]
  activities      Activity[]
  aiConfig        AiConfig?
  subscription    Subscription?
  adsTracking     AdsTracking[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// USERS — Agents, Admins, Superadmin
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  tenantId      String?   @map("tenant_id")   // null = SUPERADMIN
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(AGENT)
  fullName      String    @map("full_name")
  avatarUrl     String?   @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")

  // Refresh token (hashed, stored for revocation)
  refreshTokenHash  String?  @map("refresh_token_hash")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  assignedLeads Lead[]    @relation("AgentLeads")
  activities    Activity[]

  @@map("users")
}

// ─────────────────────────────────────────────
// CONTACTS — People who sent a WA message
// ─────────────────────────────────────────────

model Contact {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  phone         String    // E.164 format e.g. +5511999999999
  name          String?
  email         String?
  waProfilePic  String?   @map("wa_profile_pic")
  city          String?
  tags          String[]  @default([])
  customFields  Json      @default("{}") @map("custom_fields")
  optIn         Boolean   @default(false) @map("opt_in")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  leads         Lead[]
  conversations Conversation[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

// ─────────────────────────────────────────────
// LEADS — CRM core record
// ─────────────────────────────────────────────

model Lead {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  contactId           String     @map("contact_id")
  campaignId          String?    @map("campaign_id")
  assignedTo          String?    @map("assigned_to")

  stage               LeadStage  @default(NEW)
  scoreLabel          LeadScore  @default(COLD) @map("score_label")
  aiScore             Int        @default(0) @map("ai_score")   // 0-100
  dealValue           Decimal?   @map("deal_value") @db.Decimal(12, 2)
  currency            String     @default("BRL")
  lostReason          String?    @map("lost_reason")

  // AI-extracted qualification data (BANT + problem diagnosis)
  qualificationData   Json       @default("{}") @map("qualification_data")

  // ── v1.5 — Dual AI agent fields ──
  intent                  String?    // "high" | "medium" | "low" — from Qualifier AI
  problemSummary          String?    @map("problem_summary")
  nextAction              String?    @map("next_action")
  humanFollowupRequired   Boolean    @default(false) @map("human_followup_required")

  // Meta Ads attribution
  metaAdId            String?    @map("meta_ad_id")
  metaAdsetId         String?    @map("meta_adset_id")
  metaCampaignId      String?    @map("meta_campaign_id")
  sourceUtm           Json       @default("{}") @map("source_utm")

  closedAt            DateTime?  @map("closed_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  tenant              Tenant     @relation(fields: [tenantId], references: [id])
  contact             Contact    @relation(fields: [contactId], references: [id])
  campaign            Campaign?  @relation(fields: [campaignId], references: [id])
  agent               User?      @relation("AgentLeads", fields: [assignedTo], references: [id])
  conversations       Conversation[]
  activities          Activity[]
  adsTracking         AdsTracking[]

  @@index([tenantId, stage])
  @@index([tenantId, scoreLabel])
  @@index([tenantId, createdAt])
  @@index([tenantId, humanFollowupRequired])
  @@map("leads")
}

// ─────────────────────────────────────────────
// CONVERSATIONS — One per WA thread
// ─────────────────────────────────────────────

model Conversation {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  leadId            String               @map("lead_id")
  contactId         String               @map("contact_id")
  waConversationId  String?              @map("wa_conversation_id")
  status            ConversationStatus   @default(ACTIVE)
  aiEnabled         Boolean              @default(true) @map("ai_enabled")
  handoffReason     String?              @map("handoff_reason")
  lastMessageAt     DateTime?            @map("last_message_at")

  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  lead              Lead                 @relation(fields: [leadId], references: [id])
  contact           Contact              @relation(fields: [contactId], references: [id])
  messages          Message[]

  @@index([tenantId, status])
  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

// ─────────────────────────────────────────────
// MESSAGES — Every WA message in/out
// ─────────────────────────────────────────────

model Message {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  conversationId   String           @map("conversation_id")
  waMessageId      String?          @unique @map("wa_message_id")
  direction        MessageDirection
  sender           MessageSender
  type             MessageType      @default(TEXT)
  content          String?
  mediaUrl         String?          @map("media_url")
  status           MessageStatus    @default(PENDING)
  aiTokensUsed     Int              @default(0) @map("ai_tokens_used")

  // Raw AI response stored for analytics
  aiRawResponse    Json?            @map("ai_raw_response")

  sentAt           DateTime         @default(now()) @map("sent_at")
  deliveredAt      DateTime?        @map("delivered_at")
  readAt           DateTime?        @map("read_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  conversation     Conversation     @relation(fields: [conversationId], references: [id])

  @@index([tenantId, conversationId])
  @@index([waMessageId])
  @@map("messages")
}

// ─────────────────────────────────────────────
// CAMPAIGNS — Meta Ads campaign tracking
// ─────────────────────────────────────────────

model Campaign {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  name             String
  metaCampaignId   String?        @map("meta_campaign_id")
  metaAdsetId      String?        @map("meta_adset_id")
  metaAdId         String?        @map("meta_ad_id")
  budget           Decimal?       @db.Decimal(12, 2)
  spend            Decimal        @default(0) @db.Decimal(12, 2)
  impressions      Int            @default(0)
  clicks           Int            @default(0)
  status           CampaignStatus @default(ACTIVE)
  startedAt        DateTime?      @map("started_at")
  endedAt          DateTime?      @map("ended_at")

  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  leads            Lead[]

  @@index([tenantId])
  @@map("campaigns")
}

// ─────────────────────────────────────────────
// ADS TRACKING — Per-lead attribution
// ─────────────────────────────────────────────

model AdsTracking {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  leadId         String    @map("lead_id")
  metaCampaignId String?   @map("meta_campaign_id")
  metaAdsetId    String?   @map("meta_adset_id")
  metaAdId       String?   @map("meta_ad_id")
  utmSource      String?   @map("utm_source")
  utmMedium      String?   @map("utm_medium")
  utmCampaign    String?   @map("utm_campaign")
  utmContent     String?   @map("utm_content")
  utmTerm        String?   @map("utm_term")
  referrer       String?
  ipAddress      String?   @map("ip_address")

  // Meta Conversions API event tracking
  eventsSent     Json      @default("[]") @map("events_sent")

  createdAt      DateTime  @default(now()) @map("created_at")

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  lead           Lead      @relation(fields: [leadId], references: [id])

  @@index([tenantId, metaCampaignId])
  @@map("ads_tracking")
}

// ─────────────────────────────────────────────
// ACTIVITIES — CRM activity timeline
// ─────────────────────────────────────────────

model Activity {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  leadId     String       @map("lead_id")
  userId     String?      @map("user_id")
  type       ActivityType
  content    String
  metadata   Json         @default("{}")
  createdAt  DateTime     @default(now()) @map("created_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  lead       Lead         @relation(fields: [leadId], references: [id])
  user       User?        @relation(fields: [userId], references: [id])

  @@index([tenantId, leadId])
  @@map("activities")
}

// ─────────────────────────────────────────────
// AI AGENT LOG — v1.5 dual-agent audit trail
// Stores raw Qualifier + Closer outputs for every message.
// Powers the future Analyst AI (v2).
// ─────────────────────────────────────────────

model AiAgentLog {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  leadId          String   @map("lead_id")
  conversationId  String   @map("conversation_id")
  messageId       String?  @map("message_id")          // inbound message that triggered this run

  // Qualifier AI output
  qualifierOutput Json     @map("qualifier_output")    // { lead_status, score, intent, problem_summary, next_action }
  qualifierTokens Int      @default(0) @map("qualifier_tokens")
  qualifierModel  String?  @map("qualifier_model")
  qualifierMs     Int      @default(0) @map("qualifier_ms")

  // Closer AI output
  closerOutput    Json?    @map("closer_output")       // { reply_message, closing_type, urgency_trigger }
  closerTokens    Int      @default(0) @map("closer_tokens")
  closerModel     String?  @map("closer_model")
  closerMs        Int      @default(0) @map("closer_ms")

  // Final routing decision after both agents
  finalAction     String?  @map("final_action")        // "send" | "handoff" | "close" | "skipped"
  errorReason     String?  @map("error_reason")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId, leadId])
  @@index([tenantId, createdAt])
  @@index([conversationId])
  @@map("ai_agent_logs")
}

// ─────────────────────────────────────────────
// AI CONFIG — Per-tenant Claude configuration
// ─────────────────────────────────────────────

model AiConfig {
  id                    String    @id @default(uuid())
  tenantId              String    @unique @map("tenant_id")
  systemPrompt          String    @map("system_prompt") @db.Text
  qualificationCriteria Json      @default("[]") @map("qualification_criteria")
  closingScript         String?   @map("closing_script") @db.Text
  handoffTriggers       Json      @default("[]") @map("handoff_triggers")
  language              String    @default("pt-BR")
  model                 String    @default("claude-3-5-sonnet-20241022")
  temperature           Float     @default(0.3)
  maxTokens             Int       @default(512) @map("max_tokens")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant                Tenant    @relation(fields: [tenantId], references: [id])

  @@map("ai_configs")
}

// ─────────────────────────────────────────────
// BILLING / SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique @map("tenant_id")
  stripeSubId          String?            @unique @map("stripe_sub_id")
  plan                 TenantPlan         @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  contactsLimit        Int                @default(100) @map("contacts_limit")
  aiTokensLimit        BigInt             @default(100000) @map("ai_tokens_limit")
  aiTokensUsed         BigInt             @default(0) @map("ai_tokens_used")
  messagesLimit        Int                @default(1000) @map("messages_limit")
  messagesUsed         Int                @default(0) @map("messages_used")

  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}
