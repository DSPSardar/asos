# ─────────────────────────────────────────────
# ASOS v1 — Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# ── SERVER ──────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── DATABASE ─────────────────────────────────
DATABASE_URL="postgresql://asos_user:password@localhost:5432/asos_db?schema=public"

# ── DSP CRM (MySQL import source) ───────────
# Docker: MariaDB/MySQL on the host machine — use host.docker.internal (Compose adds host-gateway extra_hosts).
# Or set DSP_DB_HOST to the Docker bridge gateway (often 172.17.0.1) once MariaDB bind-address accepts it.
DSP_DB_HOST=host.docker.internal
DSP_DB_PORT=3306
DSP_DB_NAME=dsp_crm
DSP_DB_USER=dsp_crm
DSP_DB_PASSWORD=your_dsp_mysql_password

# ── REDIS ────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── WHATSAPP CLOUD API (Meta) ─────────────────
# Get from: developers.facebook.com → Your App → WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token

# ── ANTHROPIC (Claude AI) ────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=512
CLAUDE_TEMPERATURE=0.3

# ── v1.5 DUAL AGENT (optional overrides) ─────
# Qualifier = analytic; Closer = persuasive copy
QUALIFIER_MODEL=claude-haiku-4-5
CLOSER_MODEL=claude-3-5-sonnet-20241022

# ── META CONVERSIONS API ─────────────────────
META_API_VERSION=v20.0
META_API_URL=https://graph.facebook.com

# ── REPLICATE (Content Studio images, optional) ─
# Omit REPLICATE_API_TOKEN to use free Pollinations fallback instead.
# REPLICATE_MODEL=black-forest-labs/flux-dev
# REPLICATE_API_TOKEN=r8_...

# ── STRIPE ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── EMAIL (Resend) ────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── STORAGE (S3-compatible) ──────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=asos-media
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,https://app.yourdomain.com

# ── LOGGING ──────────────────────────────────
LOG_LEVEL=info
