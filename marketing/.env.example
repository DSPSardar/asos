# marketing/.env.example
# Copy to marketing/.env and fill in. Never commit the real .env or a real API key.

# ── ANTHROPIC (Claude AI) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Override the default model (see pipeline/config.js for why the default is claude-sonnet-5)
CLAUDE_MARKETING_MODEL=claude-sonnet-5

# ── ASOS BACKEND INTEGRATION ──────────────────
# Used by pipeline/leadsClient.js (DM Manager handoff) to authenticate against the real
# leads/contacts API. Must be a real user's credentials for the tenant that DSP leads
# should land in — there is no service-account/API-key auth in this backend.
MARKETING_API_BASE_URL=http://localhost:3000/api/v1
MARKETING_API_EMAIL=admin@demo-empresa.com
MARKETING_API_PASSWORD=change-me
