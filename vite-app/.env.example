# ─────────────────────────────────────────────────────
# ASOS v1 — Vite Frontend Environment Variables
# Copy to .env.local for development
# ─────────────────────────────────────────────────────

# API base URL — same-origin in production so customers stay on Vercel.
VITE_API_URL=/api/v1

# Vercel dashboard URL (also used for Stripe redirect URLs)
VITE_APP_URL=https://asos-kappa.vercel.app

# Public webhook registered in Meta Business.
VITE_WHATSAPP_WEBHOOK_URL=https://asos-kappa.vercel.app/webhooks/whatsapp

# Public branding — keeps the dashboard independent of any purchased domain.
VITE_BRAND_NAME=ASOS
VITE_MARKETING_URL=https://www.digitalservicesprogram.com
VITE_SUPPORT_EMAIL=info@digitalservicesprogram.com
VITE_SALES_EMAIL=info@digitalservicesprogram.com

# Optional: public API origin for <img src="/uploads/..."> (no /api/v1).
# Leave unset on Vercel so uploaded assets use the same public hostname.
# VITE_UPLOADS_ORIGIN=

# Server-side only. Set this in Vercel Project Settings, never in a VITE_* variable.
# It keeps the existing API/worker available behind the Vercel hostname during migration.
ASOS_BACKEND_ORIGIN=https://your-private-api-origin.example

# Feature flags
VITE_ENABLE_BILLING=true
VITE_ENABLE_META_ADS=true
VITE_ENABLE_AI_INSIGHTS=true
