# ─────────────────────────────────────────────────────
# ASOS v1 — Vite Frontend Environment Variables
# Copy to .env.local for development
# ─────────────────────────────────────────────────────

# API base URL — dev proxied by Vite, prod points to real API
VITE_API_URL=https://api.yourdomain.com/api/v1

# App URL (for Stripe redirect URLs)
VITE_APP_URL=https://app.yourdomain.com

# Optional: public API origin for <img src="/uploads/..."> (no /api/v1). Defaults from VITE_API_URL in deploy/update.sh.
# VITE_UPLOADS_ORIGIN=https://api.yourdomain.com

# Feature flags
VITE_ENABLE_BILLING=true
VITE_ENABLE_META_ADS=true
VITE_ENABLE_AI_INSIGHTS=true
