{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/proxy?_asosRoot=api/v1&_asosPath=:path*"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "/api/proxy?_asosRoot=webhooks&_asosPath=:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/proxy?_asosRoot=uploads&_asosPath=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
