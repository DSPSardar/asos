# ── Cache control for ASOS SPA ──────────────────────────────
# index.html must never be cached — browser must always fetch
# the latest entry point to get new hashed JS/CSS filenames.
<FilesMatch "^index\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Hashed JS/CSS/image assets — safe to cache forever.
# Vite adds a content hash to every filename so new build = new URL.
<FilesMatch "\.(js|css|woff2|png|jpg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
