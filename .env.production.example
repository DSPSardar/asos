# ─────────────────────────────────────────────────────────────
# ASOS v1 — Production Environment Variables
# cp .env.example .env.production && fill in all values
# NEVER commit .env.production to git
# ─────────────────────────────────────────────────────────────

# ── SERVER ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── DOMAIN (update both) ────────────────────────────────────
DOMAIN=yourdomain.com
APP_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL (Docker internal)
POSTGRES_DB=asos_db
POSTGRES_USER=asos_user
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here

# Prisma uses this (auto-assembled by docker-compose)
DATABASE_URL=postgresql://asos_user:CHANGE_ME_strong_random_password_here@postgres:5432/asos_db?schema=public

# ── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ── JWT (generate with: openssl rand -hex 64) ────────────────
JWT_SECRET=CHANGE_ME_min_64_chars_random_hex_string_here_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_different_64_chars_random_hex_string_openssl_rand_hex_64
JWT_REFRESH_EXPIRES_IN=7d

# ── WHATSAPP CLOUD API ────────────────────────────────────────
# From: developers.facebook.com → App → WhatsApp → API Setup
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_APP_SECRET=your_meta_app_secret_from_app_settings
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token_any_string

# ── ANTHROPIC (Claude AI) ─────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=512
CLAUDE_TEMPERATURE=0.3

# ── META CONVERSIONS API ──────────────────────────────────────
META_API_URL=https://graph.facebook.com
META_API_VERSION=v20.0

# ── STRIPE ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── EMAIL (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.yourdomain.com

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=warn
